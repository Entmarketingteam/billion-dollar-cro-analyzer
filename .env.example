# ── Supabase ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Shopify OAuth ────────────────────────────────
SHOPIFY_OAUTH_CLIENT_ID=your-shopify-app-id
SHOPIFY_OAUTH_CLIENT_SECRET=your-shopify-app-secret
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/shopify/oauth-callback

# ── GA4 OAuth ────────────────────────────────────
GA4_OAUTH_CLIENT_ID=your-google-client-id
GA4_OAUTH_CLIENT_SECRET=your-google-client-secret
GA4_REDIRECT_URI=http://localhost:3000/api/ga4/oauth-callback

# ── Claude API ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-api-key-here

# ── Airtable ─────────────────────────────────────
AIRTABLE_API_TOKEN=pat...your-token-here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ── Optional: Email notifications ────────────────
RESEND_API_KEY=re_...optional-for-notifications
