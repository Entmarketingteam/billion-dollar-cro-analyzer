{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": {
      "description": "Supabase project URL"
    },
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": {
      "description": "Supabase anonymous API key (public)"
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "description": "Supabase service role key (server-only, bypasses RLS)"
    },
    "SHOPIFY_OAUTH_CLIENT_ID": {
      "description": "Shopify app OAuth client ID"
    },
    "SHOPIFY_OAUTH_CLIENT_SECRET": {
      "description": "Shopify app OAuth client secret"
    },
    "SHOPIFY_REDIRECT_URI": {
      "description": "Shopify OAuth callback URL (e.g., https://yourdomain.com/api/shopify/oauth-callback)"
    },
    "GA4_OAUTH_CLIENT_ID": {
      "description": "Google OAuth 2.0 client ID for GA4 integration"
    },
    "GA4_OAUTH_CLIENT_SECRET": {
      "description": "Google OAuth 2.0 client secret for GA4 integration"
    },
    "GA4_REDIRECT_URI": {
      "description": "GA4 OAuth callback URL (e.g., https://yourdomain.com/api/ga4/oauth-callback)"
    },
    "ANTHROPIC_API_KEY": {
      "description": "Claude API key for test plan generation"
    },
    "AIRTABLE_API_TOKEN": {
      "description": "Airtable personal access token (pat...)"
    },
    "AIRTABLE_BASE_ID": {
      "description": "Airtable base ID (app...)"
    },
    "RESEND_API_KEY": {
      "description": "Optional: Resend API key for email notifications"
    },
    "SLACK_WEBHOOK_URL": {
      "description": "Optional: Slack webhook URL for notifications"
    }
  },
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
